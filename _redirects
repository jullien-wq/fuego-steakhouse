# Cloudflare Pages redirects — friendly short URLs
# Format: <from>  <to>  <status>
# NOTE: destinations use clean (extensionless) URLs. Cloudflare Pages
# auto-redirects /foo.html -> /foo, so pointing here at /foo.html causes
# an infinite redirect loop. Always target the clean URL.

# Menus
/menu              /menus                       301
/dinner            /assets/dinner-menu.pdf      302
/dinner-menu       /assets/dinner-menu.pdf      302
/brunch            /assets/brunch-menu.pdf      302
/brunch-menu       /assets/brunch-menu.pdf      302

# Entertainment / events
/events            /entertainment               301
/calendar          /entertainment               301

# Gallery & gift cards
/photos            /gallery                     301
/giftcards         /gift-cards                  301
/gift              /gift-cards                  301
/rewards           /gift-cards                  301

# Reservations / contact jump to homepage anchors
/reserve           /#contact                    301
/reservations      /#contact                    301
/contact           /#contact                    301
/private-events    /#private-events             301
