# Cloudflare Pages redirects — old Wix URLs -> new clean URLs
# Place this file at the build output root as "_redirects".
# Cloudflare Pages already serves extensionless URLs (e.g. /menus for menus.html)
# and 308-redirects /menus.html -> /menus automatically, so only the OLD paths
# that changed need rules here. 301 = permanent (preserves SEO).

# --- Renamed / moved pages ---
/private-events        /large-events        301
/events                /entertainment       301
/reviews-gallery       /gallery             301
/gift-cards-rewards    /gift-cards          301

# --- Sections / actions now on the home page ---
/contact               /#contact            301
/reservations          /#reserve            301

# --- Old pages with no direct replacement -> home (avoid 404s) ---
/about-us              /                    301
/careers               /                    301
/thank-you             /                    301
/online-orering        /                    301
/online-ordering       /                    301
